// 1. CONFIGURACIÓN DEL GENERADOR Y DATASOURCE
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. ENUMS (DEFINICIONES ESTÁTICAS DEL NEGOCIO)
enum ExerciseDifficulty {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum TieBreakerType {
  GOAL_DIFFERENCE
  GOALS_FOR
  HEAD_TO_HEAD
}

enum PlayerPosition {
  GK // Arquero
  DEF // Defensa
  MID // Volante
  FW // Delantero
}

enum Role {
  SUPERADMIN
  SUBADMIN
  DIRECTOR
  LEAGUE_OWNER
  COACH
  GUARDIAN
  PLANNER
}

enum SchoolMode {
  COMMERCIAL
  INSTITUTIONAL
}

enum SessionStatus {
  SCHEDULED // Programado
  COMPLETED // Finalizado
  CANCELLED // Cancelado
}

enum CategoryType {
  FORMATIVA
  SELECTIVA
  ADULT
  SPECIAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  PENDING
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

enum SubscriptionSaleStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum SubscriptionSaleType {
  INITIAL
  RENEWAL
}

// --- NUEVOS ENUMS ---
enum ReferralStatus {
  PENDING
  CONVERTED
  REJECTED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model AdminAuditLog {
  id String @id @default(uuid())

  // ADMIN QUE EJECUTA LA ACCIÓN
  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  // TIPO DE ACCIÓN
  action String
  // Ej: CREATE_SCHOOL, DELETE_USER, KILL_MODE, UPDATE_PLAN

  // ENTIDAD AFECTADA
  entity String
  // Ej: School, User, Tournament, PlanLimit

  entityId String?
  // ID del objeto afectado

  // ESTADO ANTERIOR Y NUEVO (AUDITORÍA REAL)
  before Json?
  after  Json?

  // METADATA EXTRA
  metadata Json?
  // Ej:
  // {
  //   ip: "192.168.1.1",
  //   userAgent: "...",
  //   reason: "fraud"
  // }

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}

model SchoolStaff {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  role Role

  createdAt DateTime @default(now())

  @@unique([userId, schoolId])
}

// 3. MODELOS PRINCIPALES
// ==========================================
// NUEVAS ENTIDADES
// ==========================================
// ==========================================
// NUEVOS ENUMS PARA EL PANEL ADMIN
// ==========================================

enum MacroEntityType {
  GOVERNMENTAL
  PRIVATE_LEAGUE
}

enum LeagueFormat {
  LARGO
  CORTO
  COPA
}

enum GlobalAssetType {
  PDF
  VIDEO
  TACTICAL_BOARD
}

enum TargetAudience {
  DIRECTOR
  COACH
  PLAYER
  GUARDIAN
}


enum ViaNotice {
  EMAIL
  APP
}

enum TournamentStatus {
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  CANCELLED
}

model MacroEntity {
  id           String          @id @default(uuid())
  name         String
  type         MacroEntityType
  schoolsLimit Int             @default(0)
  isActive     Boolean         @default(true)

  // Relaciones
  adminId String   @unique // Un usuario SubAdmin por MacroEntidad
  admin   User     @relation("MacroEntityAdmin", fields: [adminId], references: [id])
  schools School[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tournament {
  id       String           @id @default(uuid())
  name     String
  format   LeagueFormat
  settings TournamentSettings?
  status   TournamentStatus @default(PENDING_PAYMENT)

  organizerId String
  organizer   User @relation("TournamentOrganizer", fields: [organizerId], references: [id],onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  teams     TournamentTeam[]
  matches   TournamentMatch[]
  standings TournamentStanding[]

  plannerId String
  planner   User @relation("TournamentPlanner", fields: [plannerId], references: [id],onDelete: Cascade)

}

model TournamentSettings {
  id String @id @default(uuid())

  tournamentId String @unique
  tournament   Tournament @relation(fields: [tournamentId], references: [id],onDelete:Cascade)

  // ⚽ FORMATO GENERAL
  maxTeams Int?
  rounds Int? // cantidad de vueltas (ida, ida/vuelta)

  // 🏆 PUNTOS
  pointsWin  Int @default(3)
  pointsDraw Int @default(1)
  pointsLoss Int @default(0)

  // ⚖️ REGLAS DE DESEMPATE
  tieBreaker TieBreakerType @default(GOAL_DIFFERENCE)

  // 🥅 GOLES
  allowDraws Boolean @default(true)

  // 🏁 PLAYOFFS
  hasPlayoffs Boolean @default(false)
  playoffTeams Int? // ej: 4 u 8

  // 👥 GRUPOS
  hasGroups Boolean @default(false)
  groupsCount Int?

  // ⏱ CONFIG PARTIDOS
  matchDuration Int @default(90) // minutos
  allowExtraTime Boolean @default(false)
  allowPenalties Boolean @default(false)

  // 📅 CONFIG CALENDARIO
  matchesPerWeek Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TournamentTeam {
  id   String @id @default(uuid())
  name String
  logoUrl String?

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  players   TournamentPlayer[]
  standings TournamentStanding[]

  // Relaciones inversas de partidos
  homeMatches TournamentMatch[] @relation("HomeTeam")
  
  
  awayMatches TournamentMatch[] @relation("AwayTeam")
}

model TournamentPlayer {
  id String @id @default(uuid())

  firstName String
  lastName  String
  number    Int?

  position PlayerPosition?

  teamId String
  team   TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  stats TournamentPlayerStat[]
  matchEvents TournamentMatchEvent[]
  rosterValidations TournamentMatchRoster[]

  createdAt DateTime @default(now())
}

model TournamentMatch {
  id String @id @default(uuid())

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  homeTeamId String
  awayTeamId String

  homeTeam TournamentTeam @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam TournamentTeam @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)

  homeScore Int @default(0)
  awayScore Int @default(0)

  date DateTime
  round Int

  currentPeriod MatchPeriod @default(PREVIA)
  notes String?
  startedAt DateTime?
  finishedAt DateTime?
  submittedAt DateTime?



  status MatchStatus

  stats TournamentPlayerStat[]
  events TournamentMatchEvent[]
  rosterValidations TournamentMatchRoster[]

  @@index([tournamentId])
}

model TournamentMatchEvent {
  id String @id @default(uuid())

  matchId String
  match TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  playerId String?
  player TournamentPlayer? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  teamSide MatchTeamSide
  type MatchEventType
  minute Int
  description String?

  createdAt DateTime @default(now())
}

model TournamentMatchRoster {
  id String @id @default(uuid())

  matchId String
  match TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  playerId String
  player TournamentPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  teamSide MatchTeamSide
  verified Boolean @default(false)
  suspendedSnapshot Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([matchId, playerId])
}

model TournamentPlayerStat {
  id String @id @default(uuid())

  playerId String
  player   TournamentPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  matchId String
  match   TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  goals Int @default(0)
  assists Int @default(0)
  yellowCards Int @default(0)
  redCards Int @default(0)

  @@unique([playerId, matchId])
}

model TournamentStanding {
  id String @id @default(uuid())

  teamId String
  team   TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  played Int @default(0)
  wins Int @default(0)
  draws Int @default(0)
  losses Int @default(0)

  goalsFor Int @default(0)
  goalsAgainst Int @default(0)

  points Int @default(0)

  @@unique([teamId, tournamentId])
}

enum MatchStatus {
  SCHEDULED
  ROSTER_LOCKED
  IN_PROGRESS
  FINISHED
  SUBMITTED
  PLAYED
  CANCELLED
}

enum MatchPeriod {
  PREVIA
  FIRST_HALF
  BREAK
  SECOND_HALF
  FINAL
}

enum MatchTeamSide {
  HOME
  AWAY
}

enum MatchEventType {
  GOAL
  YELLOW
  RED
}

model GlobalAsset {
  id             String          @id @default(uuid())
  title          String
  description    String?
  type           GlobalAssetType
  targetAudience TargetAudience
  url            String
  isActive       Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key       String   @id // Ej: 'MAINTENANCE_MODE'
  value     String // Ej: 'true' o 'false'
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  photoUrl  String?
  phone     String?
  role      Role     @default(GUARDIAN)
  planLimitId String?
  planLimit PlanLimit? @relation(fields: [planLimitId], references: [id])
  flowCustomerId String? @unique
  flowSubscriptionId String?
  flowPlanId String?
  flowSubscriptionStatus String?
  flowCardStatus String?
  flowCardLast4 String?
  flowCardType String?
  flowLastPaymentStatus Int?
  flowLastToken String?
  flowCurrentPeriodEnd DateTime?
  flowNextBillingDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  strategys      Strategy[] // Estrategias creadas por el entrenador
  schools        SchoolStaff[] // 👈 relación múltiple
  managedPlayers Player[]       @relation("GuardianPlayers")
  coachProfile   Coach?
  notifications  Notification[]

  macroEntity   MacroEntity?    @relation("MacroEntityAdmin") // Si el user es SubAdmin
  tournaments   Tournament[]    @relation("TournamentOrganizer") //
  // --- NUEVAS RELACIONES ---
  assignedTasks Task[]          @relation("UserTasks") // Tareas asignadas al usuario (Staff)
  adminAuditLog AdminAuditLog[]
  subscriptionSales SubscriptionSale[]
  schoolGalleryPhotos SchoolGalleryPhoto[] @relation("SchoolGalleryPhotosCreatedBy")
  flowWebhookEvents FlowWebhookEvent[]
  supportTickets SupportTicket[]
  
  tournamentPlanners Tournament[]  @relation("TournamentPlanner") //
}

model SupportTicket {
  id        String   @id @default(uuid())
  title     String
  message   String   @db.Text
  status    String   @default("OPEN")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model FlowWebhookEvent {
  id String @id @default(uuid())
  token String @unique
  eventType String
  payload Json?
  status String
  error String?
  processedAt DateTime?
  directorId String?
  director User? @relation(fields: [directorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventType, createdAt])
}

model School {
  id                 String     @id @default(uuid())
  name               String
  slug               String     @unique
  logoUrl            String?
  mode               SchoolMode @default(COMMERCIAL)
  bankDetails        String?    @db.Text
  subscriptionStatus String?
  nextBillingDate    DateTime?
  macroEntityId      String?
  macroEntity        MacroEntity? @relation(fields: [macroEntityId], references: [id])

  isActive Boolean? @default(true) // Usado para el "Kill Mode"

  users      User[]
  categories Category[]
  players    Player[]
  products   Product[]
  exercises  Exercise[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt


  monthlyFee Float @default(20000)
  latitude   Float?
  longitude  Float?

  staff         SchoolStaff[] // 👈 directores, coaches, etc.

  monthlyPayments MonthlyFee[]

  // --- NUEVAS RELACIONES ---
  // Growth Hacking: Sistema de Referidos
  referralsSent     Referral[] @relation("SchoolReferrer")
  referralsReceived Referral[] @relation("SchoolReferee")

  // Monetización: Espacios de Patrocinio
  sponsorships Sponsorship[]

  // Modo Institucional: Beneficios
  benefits Benefit[]

  // Gestión Interna
  tasks Task[]

  notices Notice[]
  galleryPhotos SchoolGalleryPhoto[]

  @@index([macroEntityId])
}

model SchoolGalleryPhoto {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  key     String
  caption String?

  createdById String?
  createdBy   User? @relation("SchoolGalleryPhotosCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
}

model Notice {
  id      String  @id @default(uuid())
  title   String
  summary String
  content String  @db.Text
  image   String?
  status  String  @default("draft") // "draft" | "published"
  views   Int     @default(0)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id       String       @id @default(uuid())
  name     String
  type     CategoryType @default(FORMATIVA)
  schoolId String
  school   School       @relation(fields: [schoolId], references: [id])

  players         Player[]
  coaches         Coach[]           @relation("CoachCategories")
  sessions        TrainingSession[]
  matches         Match[]
  tacticalsBoards TacticalBoard[] // Relación con Partidos
}

model SessionTacticalBoard {
  id String @id @default(uuid())

  // Relación con la Sesión
  sessionId       String
  trainingSession TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Relación con la Pizarra
  boardId       String
  tacticalBoard TacticalBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  // Metadatos de la relación
  orderIndex Int     @default(0) // Importante para el ordenamiento en el frontend
  notes      String? // Notas opcionales para este momento específico

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([boardId])
}

// Modelo Principal de la Pizarra
model TacticalBoard {
  id          String  @id @default(uuid())
  title       String
  description String? @db.Text

  // Relación con Categoría
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id])

  // Estado INICIAL de la pizarra (tokens y dibujos al empezar)
  initialState Json // Guardaremos { tokens: [], strokes: [] }

  // Animación (Array de frames)
  animation Json? // Guardaremos [ { tokens: [], strokes: [] }, ... ]

  // Metadatos
  tags String[] // Ej: "Salida", "Corner", "Presión Alta"

  authorId  String // Quién la creó
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions SessionTacticalBoard[] // Para saber en qué sesiones se usó esta pizarra
}

model Player {
  id          String         @id @default(uuid())
  firstName   String
  lastName    String
  rut         String?
  birthDate   DateTime
  photoUrl    String?
  medicalInfo String?        @db.Text
  active      Boolean        @default(true)
  scholarship Boolean        @default(false)
  position    PlayerPosition @default(DEF) // <--- Agregar este campo
  qrCodeToken String         @unique @default(uuid())

  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  guardianId String
  guardian   User     @relation("GuardianPlayers", fields: [guardianId], references: [id])

  attendance      Attendance[]
  evaluations     Evaluation[]
  monthlyPayments MonthlyFee[]
  matchStats      MatchStat[] // Relación con Estadísticas de Partidos

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  @@unique([schoolId, rut])
}

model Coach {
  id     String  @id @default(uuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id])
  bio    String?

  categories Category[] @relation("CoachCategories")

  // --- NUEVAS RELACIONES ---
  tacticalBoards TacticalBoard[] // Pizarras creadas por el entrenador
}

// 4. MÓDULO DE ENTRENAMIENTO Y CONTENIDOS

model Exercise {
  id          String @id @default(uuid())
  title       String
  description String @db.Text

  // === NUEVOS CAMPOS ===
  objective  String? // Ej: "Mejorar control orientado"
  difficulty ExerciseDifficulty @default(BASIC) // BASIC, INTERMEDIATE, ADVANCED

  // Multimedia
  videoUrl String?
  imageUrl String?

  // === VISIBILIDAD Y PERMISOS ===
  isGlobal Boolean @default(false) // Si es TRUE, es un ejercicio del sistema (La Novena) para todos.

  // Relación con Escuela (Opcional si es global)
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  // Auditoría: Quién lo creó (Director o Entrenador)
  authorId String?
  // Si tienes un modelo User, podrías descomentar esto:
  // author    User?    @relation(fields: [authorId], references: [id])

  // Etiquetas (ej: ["Físico", "Táctico", "Sub-12"])
  tags String[]

  // Relación con las sesiones de entrenamiento
  sessionItems SessionExercise[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingSession {
  id             String                 @id @default(uuid())
  title          String?
  location       String?
  status         SessionStatus?         @default(SCHEDULED)
  date           DateTime
  notes          String?
  categoryId     String
  category       Category               @relation(fields: [categoryId], references: [id])
  evaluations    Evaluation[]
  exercises      SessionExercise[]
  attendance     Attendance[]
  tacticalBoards SessionTacticalBoard[] // Relación con las pizarras
  // --- NUEVAS RELACIONES ---

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model SessionExercise {
  id          String          @id @default(uuid())
  sessionId   String
  session     TrainingSession @relation(fields: [sessionId], references: [id])
  exerciseId  String
  exercise    Exercise        @relation(fields: [exerciseId], references: [id])
  orderIndex  Int
  durationMin Int?
}

model Attendance {
  id        String           @id @default(uuid())
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  rating    Int?
  feedback  String?
  // Relaciones
  player    Player           @relation(fields: [playerId], references: [id])
  playerId  String

  session   TrainingSession @relation(fields: [sessionId], references: [id])
  sessionId String

  // ⚠️ CLAVE: Esto permite buscar rápido y evitar duplicados
  @@unique([sessionId, playerId])
}

// --- MÓDULO DE PARTIDOS (MATCHES) ---

model Match {
  id         String   @id @default(uuid())
  rivalName  String
  date       DateTime
  isHome     Boolean  @default(true)
  location   String?
  notes      String?
  

  // Relación con categoría
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Relación con estadísticas
  stats MatchStat[]
}

model MatchStat {
  id      String @id @default(uuid())
  goals   Int    @default(0)
  assists Int    @default(0)

  matchId String
  match   Match  @relation(fields: [matchId], references: [id])

  playerId String
  player   Player @relation(fields: [playerId], references: [id])
}

// --- FIN MÓDULO PARTIDOS ---
// 1. Categorías (Dimensiones del Radar y de clasificación)
// 1. Enums
enum EvaluationCategory {
  TECHNICAL
  PHYSICAL
  TACTICAL
  MENTAL
  SPEED
}

enum MeasurementUnit {
  SECONDS
  METERS
  CENTIMETERS
  POINTS
  PERCENTAGE
  COUNT
}

// 2. NUEVO: Modelo de Protocolos (Tests Dinámicos)
model TestProtocol {
  id          String @id @default(uuid())
  name        String @unique // Ej: "Velocidad 30m"
  description String @db.Text

  category EvaluationCategory // ✅ Clasifica el test (Físico, Técnico, etc.)
  unit     MeasurementUnit // ✅ Qué unidad usa este test específico

  isGlobal   Boolean @default(true) // Creado por SuperAdmin
  baremoJson String? @db.Text // JSON de referencia

  evaluations Evaluation[]
}


// 3. Modelo de Evaluación (Normalizado)
model Evaluation {
  id   String   @id @default(uuid())
  date DateTime @default(now())

  value Float // El resultado del jugador
  notes String? @db.Text

  // Relación con el Test
  protocolId String
  protocol   TestProtocol @relation(fields: [protocolId], references: [id])

  // Relación con el Jugador
  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  sessionId String?
  session   TrainingSession? @relation(fields: [sessionId], references: [id])
}

model Strategy {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relación con el creador (Entrenador)
  coachId String
  coach   User   @relation(fields: [coachId], references: [id])

  // DATOS DE LA PIZARRA
  // Guardamos las posiciones de las fichas como un JSON
  tokens Json

  // Guardamos las líneas dibujadas. 
  // Opción A: Base64 String (Fácil, pero ocupa espacio en DB).
  // Opción B: Array de coordenadas (Más optimizado, más difícil de programar).
  // Usaremos Opción A por simplicidad ahora:
  drawingData String? @db.Text
}

// 5. MÓDULO COMERCIAL

model MonthlyFee {
  id          String        @id @default(uuid())
  month       Int
  year        Int
  amount      Float
  status      PaymentStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  playerId    String
  player      Player        @relation(fields: [playerId], references: [id])
  paymentDate DateTime?
  createdAt DateTime? @default(now())
  // --- NUEVA RELACIÓN DIRECTA (OPTIMIZACIÓN) ---
  schoolId      String
  school        School  @relation(fields: [schoolId], references: [id])
  paymentMethod String?

  receiptUrl String?

  @@unique([playerId, month, year])
}

model GlobalNotice {
  id       String  @id @default(uuid())
  targetAudience TargetAudience?
  title          String
  description    String
  via ViaNotice
  createdAt DateTime? @default(now())
}

model Product {
  id       String  @id @default(uuid())
  name     String
  price    Float
  stock    Int
  imageUrl String?
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id])
  active   Boolean @default(true)
}

// 6. SISTEMA

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
}

// ==========================================
// 7. NUEVOS MÓDULOS (ALINEACIÓN FUNCIONAL)
// ==========================================

// --- A. GROWTH HACKING (REFERIDOS) ---
model Referral {
  id String @id @default(uuid())

  referrerSchoolId String
  referrerSchool   School @relation("SchoolReferrer", fields: [referrerSchoolId], references: [id])

  referredSchoolEmail String // Email invitado antes de que se cree la escuela
  referredSchoolId    String? // Se llena cuando la escuela se crea
  referredSchool      School? @relation("SchoolReferee", fields: [referredSchoolId], references: [id])

  status        ReferralStatus @default(PENDING)
  rewardClaimed Boolean        @default(false) // Si ya se aplicó el mes gratis

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- B. MONETIZACIÓN LOCAL (PUBLICIDAD) ---
model Sponsorship {
  id          String  @id @default(uuid())
  name        String // Ej: "Dentista San José"
  imageUrl    String // Banner publicitario
  redirectUrl String? // Link al sitio del sponsor
  location    String // Ej: "APP_BOTTOM_BANNER", "LOADING_SCREEN"

  isActive  Boolean  @default(true)
  startDate DateTime
  endDate   DateTime

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
}

// --- C. MODO INSTITUCIONAL (BENEFICIOS) ---
model Benefit {
  id          String  @id @default(uuid())
  title       String // Ej: "Gratuidad por Asistencia"
  description String  @db.Text // Ej: "Mantener 80% de asistencia mensual"
  active      Boolean @default(true)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
}

// --- E. GESTIÓN & OPERACIONES (KANBAN) ---
model Task {
  id          String       @id @default(uuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  position    Int // <-- Nuevo campo añadido
  dueDate     DateTime?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  assignedToUserId String?
  assignedToUser   User?   @relation("UserTasks", fields: [assignedToUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- F. CONFIGURACIÓN DE PLANES (LIMITES) ---
model PlanLimit {
  id                    String   @id @default(uuid())
  name                  String
  amount                Int
  isActive              Boolean  @default(true)
  interval              String   @default("BOTH")
  flowId                String?
  flowIdYearly          String?
  maxSchools            Int
  maxPlayersPerSchool   Int
  maxCategories         Int
  maxCoaches            Int      @default(2)
  maxGuardianPerPlayer  Int      @map("maxGuardianPerSchools")

  directors User[]
  subscriptionSales SubscriptionSale[]
}

model SubscriptionSale {
  id String @id @default(uuid())

  directorId String
  director User @relation(fields: [directorId], references: [id])

  planLimitId String?
  planLimit PlanLimit? @relation(fields: [planLimitId], references: [id])

  flowSubscriptionId String?
  flowToken String? @unique
  flowOrder String?

  amount Int
  currency String @default("CLP")
  billingCycle String
  periodKey String

  saleType SubscriptionSaleType
  status SubscriptionSaleStatus
  paidAt DateTime?

  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([directorId, createdAt])
  @@index([status, createdAt])
  @@index([periodKey])
  @@unique([flowSubscriptionId, saleType, periodKey])
}
